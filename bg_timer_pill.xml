<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <size android:width="44dp" android:height="44dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="22dp"
                android:startColor="#66FF6B1A"
                android:endColor="#00000000" />
        </shape>
    </item>
    <item android:width="18dp" android:height="18dp" android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="@color/lava_orange_bright" />
            <stroke android:width="3dp" android:color="@color/text_primary" />
        </shape>
    </item>
</layer-list>
