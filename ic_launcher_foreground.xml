<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lava_black">

    <!-- OpenStreetMap view (free, no API key) -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Top gradient scrim for status bar readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/scrim_top"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/gameTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FLOOR IS LAVA"
        android:textColor="@color/lava_gold"
        android:textStyle="bold"
        android:textSize="20sp"
        android:letterSpacing="0.04"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Timer pill, centered top -->
    <TextView
        android:id="@+id/timerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:30"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:textSize="26sp"
        android:fontFamily="monospace"
        android:background="@drawable/bg_timer_pill"
        android:layout_marginTop="56dp"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status subtitle under timer -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/finding_location"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/timerText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Distance readout, bottom above button -->
    <TextView
        android:id="@+id/distanceText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/lava_yellow"
        android:textStyle="bold"
        android:textSize="16sp"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@id/startButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="18dp" />

    <!-- Bottom scrim -->
    <View
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/scrim_bottom"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Start / Lava button -->
    <FrameLayout
        android:id="@+id/startButton"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/selector_start_button"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/startButtonText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/start_button"
            android:textColor="@color/lava_black"
            android:textStyle="bold"
            android:textSize="18sp"
            android:letterSpacing="0.05" />
    </FrameLayout>

    <!-- Recenter / my-location button -->
    <ImageButton
        android:id="@+id/recenterButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/bg_recenter_button"
        android:src="@drawable/ic_recenter"
        android:contentDescription="Recenter map"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="@id/startButton"
        app:layout_constraintTop_toTopOf="@id/startButton"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Result overlay (win/lose) -->
    <FrameLayout
        android:id="@+id/resultOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/overlay_dark"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/resultPanel"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp"
            android:background="@drawable/bg_lose_panel">

            <TextView
                android:id="@+id/resultIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌋"
                android:textSize="52sp" />

            <TextView
                android:id="@+id/resultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lose_title"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="22sp"
                android:gravity="center"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/resultSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="6dp" />

            <Button
                android:id="@+id/playAgainButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="22dp"
                android:text="@string/play_again"
                android:textColor="@color/lava_black"
                android:textStyle="bold"
                android:background="@drawable/bg_play_again_button"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
